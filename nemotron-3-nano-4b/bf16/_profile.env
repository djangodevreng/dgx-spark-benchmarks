# NVIDIA-Nemotron-3-Nano-4B BF16
# vLLM cu130-nightly image (Blackwell-class GPUs / DGX Spark GB10)
# 4B dense hybrid (Mamba-2 + Transformer + MLP), 49k context
# Bron: https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Nano-4B-BF16

PROFILE_NAME="bf16"
VLLM_IMAGE="vllm/vllm-openai:cu130-nightly"

MODEL_HF="nvidia/NVIDIA-Nemotron-3-Nano-4B-BF16"
MODEL_SERVED="nemotron-3-nano-4b-bf16"
MODEL_DIR="nemotron-3-nano-4b"

# Native context is 49k (kleinste van alle profielen) — niet kunstmatig naar 131k tillen.
# Onze tests gaan tot 25k, ruim binnen 49k.
MAX_MODEL_LEN="49152"
GPU_MEMORY_UTILIZATION="0.95"
KV_CACHE_DTYPE="fp8_e4m3"
ENABLE_PREFIX_CACHING="false"
ASYNC_SCHEDULING="true"
LIMIT_MM_PER_PROMPT='{"image":0,"audio":0}'

EXTRA_VLLM_ARGS="--trust-remote-code"
