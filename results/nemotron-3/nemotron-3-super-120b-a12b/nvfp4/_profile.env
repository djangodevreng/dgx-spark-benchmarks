# NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4 — DGX Spark
# 120B totaal / 12B actief LatentMoE (Mamba-2 + MoE + Attention hybrid + MTP)
# Bron: https://docs.nvidia.com/nemotron/nightly/usage-cookbook/Nemotron-3-Super/SparkDeploymentGuide/
#
# LET OP: vereist parser plugin gemount in container, 4 Spark-specifieke env vars,
# en een gepatche bench-spark CLI met PROFILE_ENV_VARS + PROFILE_VOLUMES support.

PROFILE_NAME="nvfp4"
VLLM_IMAGE="vllm/vllm-openai:cu130-nightly"

MODEL_HF="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"
MODEL_SERVED="nemotron-3-super"
MODEL_DIR="nemotron-3-super-120b-a12b"

# 131072 voor parity met andere Spark-profielen — model claimt 1M maar voor onze
# benchmark suite (max 25k) is 131k ruim voldoende, scheelt boot-memory pressure.
MAX_MODEL_LEN="131072"
GPU_MEMORY_UTILIZATION="0.95"
KV_CACHE_DTYPE="fp8"
ENABLE_PREFIX_CACHING="false"
ASYNC_SCHEDULING="true"
LIMIT_MM_PER_PROMPT='{"image":0,"audio":0}'

# Spark-specifieke env vars (binnen container)
PROFILE_ENV_VARS="VLLM_NVFP4_GEMM_BACKEND=marlin VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 VLLM_FLASHINFER_ALLREDUCE_BACKEND=trtllm VLLM_USE_FLASHINFER_MOE_FP4=0"

# Reasoning parser plugin file mount
PROFILE_VOLUMES="/home/spark/benchmarks/bench-spark/parsers/super_v3_reasoning_parser.py:/app/super_v3_reasoning_parser.py"

# Speculative config JSON moet zonder spaties (bash word-splitting); single quotes om $ te escapen
EXTRA_VLLM_ARGS='--trust-remote-code --enable-chunked-prefill --max-num-seqs 20 --moe-backend marlin --mamba_ssm_cache_dtype float32 --quantization fp4 --speculative_config {"method":"mtp","num_speculative_tokens":3,"moe_backend":"triton"} --reasoning-parser-plugin /app/super_v3_reasoning_parser.py --reasoning-parser super_v3 --enable-auto-tool-choice --tool-call-parser qwen3_coder'
