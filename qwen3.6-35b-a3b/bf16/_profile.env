# Qwen3.6-35B-A3B BF16 (MoE: 256 experts, 8 routed + 1 shared, 3B active)
# vLLM cu130-nightly image (Blackwell-class GPUs / DGX Spark GB10)
# Text-only benchmarking — vision encoder uitgeschakeld via --language-model-only

PROFILE_NAME="bf16"
VLLM_IMAGE="vllm/vllm-openai:cu130-nightly"

MODEL_HF="Qwen/Qwen3.6-35B-A3B"
MODEL_SERVED="qwen3.6-35b-a3b-bf16"
MODEL_DIR="qwen3.6-35b-a3b"

MAX_MODEL_LEN="131072"
GPU_MEMORY_UTILIZATION="0.95"
KV_CACHE_DTYPE="auto"
ENABLE_PREFIX_CACHING="false"
ASYNC_SCHEDULING="false"
LIMIT_MM_PER_PROMPT='{"image":0,"audio":0}'

EXTRA_VLLM_ARGS="--language-model-only --reasoning-parser qwen3 --trust-remote-code"
